+def _dispatch_task(args: argparse.Namespace) -> int:
+    """Диспетчер подкоманд task."""
+    if not args.task_command:
+        print("❌ No task subcommand provided. Use: create, list, start, complete, show, generate")
+        return 1
+    if args.task_command == "create":
+        return task_create(args)
+    if args.task_command == "list":
+        return task_list(args)
+    if args.task_command == "start":
+        return task_start(args)
+    if args.task_command == "complete":
+        return task_complete(args)
+    if args.task_command == "show":
+        return task_show(args)
+    if args.task_command == "generate":
+        return generate_task(args)
+    return 1
+
