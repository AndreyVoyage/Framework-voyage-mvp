+def task_create(args: argparse.Namespace) -> int:
+    """Создать новую задачу в Task Engine."""
+    from voyage_framework.core.task_engine import TaskManager
+
+    engine = EventEngine()
+    manager = TaskManager(event_engine=engine)
+    task = manager.create(
+        title=args.title,
+        description=args.description,
+        role=args.role,
+        project_id=args.project or "default",
+        criteria=args.criteria.split(";") if args.criteria else [],
+    )
+    print(f"✅ Task created: {task.task_id}")
+    print(f"   Title:  {task.title}")
+    print(f"   Role:   {task.role}")
+    print(f"   Status: {task.status.value}")
+    return 0
+
+
+def task_list(args: argparse.Namespace) -> int:
+    """Показать список задач."""
+    from voyage_framework.core.task_engine import TaskManager, TaskStatus
+
+    manager = TaskManager()
+    status = TaskStatus(args.status) if args.status else None
+    tasks = manager.list(
+        project_id=args.project,
+        role=args.role,
+        status=status,
+        limit=args.limit,
+    )
+
+    if not tasks:
+        print("📝 No tasks found")
+        return 0
+
+    print(f"📝 Tasks ({len(tasks)}):")
+    print(f"{'ID':10} {'Status':12} {'Role':12} {'Title'}")
+    print("-" * 60)
+    for t in tasks:
+        short_id = t.task_id[:8]
+        print(f"{short_id:10} {t.status.value:12} {t.role:12} {t.title[:40]}")
+    return 0
+
+
+def task_start(args: argparse.Namespace) -> int:
+    """Начать задачу."""
+    from voyage_framework.core.task_engine import TaskManager
+
+    manager = TaskManager()
+    try:
+        task = manager.start(args.task_id)
+        print(f"🚀 Task started: {task.task_id}")
+        print(f"   Status: {task.status.value}")
+    except ValueError as e:
+        print(f"❌ {e}")
+        return 1
+    return 0
+
+
+def task_complete(args: argparse.Namespace) -> int:
+    """Завершить задачу."""
+    from voyage_framework.core.task_engine import TaskManager
+
+    manager = TaskManager()
+    try:
+        task = manager.complete(args.task_id)
+        print(f"✅ Task completed: {task.task_id}")
+        print(f"   Status: {task.status.value}")
+    except ValueError as e:
+        print(f"❌ {e}")
+        return 1
+    return 0
+
+
+def task_show(args: argparse.Namespace) -> int:
+    """Показать детали задачи."""
+    from voyage_framework.core.task_engine import TaskManager
+
+    manager = TaskManager()
+    task = manager.get(args.task_id)
+    if task is None:
+        print(f"❌ Task not found: {args.task_id}")
+        return 1
+
+    print(f"📋 Task {task.task_id}")
+    print(f"   Title:       {task.title}")
+    print(f"   Status:      {task.status.value}")
+    print(f"   Role:        {task.role}")
+    print(f"   Project:     {task.project_id}")
+    print(f"   Created:     {task.created_at}")
+    if task.started_at:
+        print(f"   Started:     {task.started_at}")
+    if task.completed_at:
+        print(f"   Completed:   {task.completed_at}")
+    if task.criteria:
+        print(f"   Criteria:")
+        for c in task.criteria:
+            print(f"      - {c}")
+    if task.description:
+        print(f"   Description: {task.description[:100]}")
+    return 0
+
+
